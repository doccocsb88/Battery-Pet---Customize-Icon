					<Image tint="argb(255,#r[#sz_color],#g[#sz_color],#b[#sz_color])" src="time1/time.png" x="0" y="0" alignV="center" align="left" visibility="eq(#time_format,0)" centerX="#timea.bmp_width" name="timea" srcid="ifelse(eq(#hour12,0),1,#hour12/10)"/>
