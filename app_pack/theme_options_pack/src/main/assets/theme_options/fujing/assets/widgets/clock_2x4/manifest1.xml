					<Image tint="argb(255,#r[#sz_color],#g[#sz_color],#b[#sz_color])" src="time1/time.png" x="0" y="0" alignV="center" align="left" visibility="eq(#time_format,1)" centerX="#timea.bmp_width" name="timea" srcid="int(#hour24/10)"/>
					<Image tint="argb(255,#r[#sz_color],#g[#sz_color],#b[#sz_color])" src="time1/time.png" x="15+#timea.bmp_width" y="0" alignV="center" align="left" visibility="eq(#time_format,0)" centerX="#timeb.bmp_width" name="timeb" srcid="ifelse(eq(#hour12,0),2,#hour12%10)"/>
					<Image tint="argb(255,#r[#sz_color],#g[#sz_color],#b[#sz_color])" src="time1/time.png" x="15+#timea.bmp_width" y="0" alignV="center" align="left" visibility="eq(#time_format,1)" centerX="#timeb.bmp_width" name="timeb" srcid="#hour24%10"/>
				</Group>
				<Group visibility="#sjys_num==0" y="0.205*#view_height" x="-204*#YC_Ani2" scale="#view_height/527" alpha="255*#YC_Ani2">
					<Image tint="argb(255,#r[#sz_color],#g[#sz_color],#b[#sz_color])" src="time/time.png" x="31+#timea.bmp_width+#timeb.bmp_width" y="0" alignV="center" align="left" centerX="#timec.bmp_width" name="timec" srcid="int(#minute/10)"/>
					<Image tint="argb(255,#r[#sz_color],#g[#sz_color],#b[#sz_color])" src="time/time.png" x="46+#timea.bmp_width+#timeb.bmp_width+#timec.bmp_width" y="0" alignV="center" align="left" centerX="#timed.bmp_width" name="timed" srcid="#minute%10"/>
				</Group>
				<!-- 2 -->
