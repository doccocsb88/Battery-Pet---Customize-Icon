<?xml version="1.0" encoding="utf-8"?>
<Aod frameRate="144" screenWidth="1080" version="1">
	<!-- aod模块注意事项；1.动画触发放在下方 Trigger 中；2.动画时长不超过4s，超过部分将会被强制停止；3.息屏中 动画仅播放一次，此后每分钟仅做 时间 的刷新，不可加动画 -->
	<ExternalCommands>
		<Trigger action="init">
			<ExternCommand command="animationState" strPara="'init'"/>
		</Trigger>
		<Trigger action="play">
			<AnimationCommand target="YC_Ani" command="play"/>
			<AnimationCommand target="YC_Ani1" command="play"/>
		</Trigger>
	</ExternalCommands>
	<VariableBinders>
		<ContentProviderBinder name="data" uri="content://aod.notification/notifications" columns="pkg" countName="hasnotifications">
			<Variable name="noticePkg" type="string[]" column="pkg"/>
			<Trigger>
				<VariableCommand name="noticeCount" type="number" expression="min(#hasnotifications-1,3)"/>
			</Trigger>
		</ContentProviderBinder>
	</VariableBinders>
	<!-- 变量动画 -->
	<Var name="YC_Ani">
		<VariableAnimation loop="false" initPause="false">
			<AniFrame value="0" time="0" easeType="BackEaseOut"/>
			<AniFrame value="1" time="2000"/>
		</VariableAnimation>
	</Var>
	<Var name="YC_Ani1">
		<VariableAnimation loop="false" initPause="false">
			<AniFrame value="0" time="300" easeType="BackEaseOut"/>
			<AniFrame value="1" time="2000"/>
		</VariableAnimation>
	</Var>
	<Var name="timeAni">
		<VariableAnimation loop="false" initPause="true">
			<AniFrame value="0" time="0" easeType="ElasticEaseOut"/>
			<AniFrame value="1" time="2500"/>
		</VariableAnimation>
	</Var>
	<Var name="chargeAni">
		<VariableAnimation loop="false" initPause="true">
			<AniFrame value="0" time="0" easeType="CubicEaseOut"/>
			<AniFrame value="#battery_level" time="1000"/>
		</VariableAnimation>
	</Var>
	<Var name="endAni">
		<VariableAnimation name="endAnimation" loop="false" initPause="true">
			<AniFrame value="0" time="0"/>
			<AniFrame value="1" time="2500"/>
			<Triggers>
				<Trigger action="end" condition="#endAnimation.current_frame==-1">
					<!-- 有动画的aod，一定要在 最长的动画 结束之后给系统发个命令，注意：此命令只能存在一个，请勿使用多个 -->
					<ExternCommand command="animationState" strPara="'finish'"/>
				</Trigger>
			</Triggers>
		</VariableAnimation>
	</Var>
	<Var name="noticeApp" type="string[]" const="true" expression="" values="'com.android.contacts,com.android.contacts.activities.TwelveKeyDialer','com.android.mms','com.android.email','com.android.thememanager'"/>
	<Group align="center" alignV="center" x="540" y="300" w="411" h="411" layered="true">
		<Image w="412" h="412" src="1.png"/>
		<!--8-->
		<Image w="43" h="43" x="110" y="120" src="8.png">
			<!--位移-->
			<PositionAnimation loop="false">
				<Item x="120" y="110" time="1600" easeType="BackEaseOut"/>
				<Item x="120" y="60" time="2600"/>
			</PositionAnimation>
			<!--透明度-->
			<AlphaAnimation loop="false">
				<Item value="0" time="0"/>
				<Item value="0" time="1601" easeType="BackEaseOut"/>
				<Item value="255" time="2600"/>
			</AlphaAnimation>
		</Image>
		<Image w="179" h="61" x="50" y="40" src="7.png">
			<!--位移-->
			<PositionAnimation loop="false">
				<Item x="120" y="190" time="800" easeType="QuintEaseOut"/>
				<Item x="120" y="60" time="1800"/>
			</PositionAnimation>
			<!--非等比缩放-->
			<SizeAnimation loop="false">
				<Item w="0" h="61" time="0"/>
				<Item w="1" h="61" time="1200" easeType="BackEaseOut"/>
				<Item w="179" h="61" time="2200"/>
			</SizeAnimation>
			<!--透明度-->
			<AlphaAnimation loop="false">
				<Item value="0" time="0"/>
				<Item value="0" time="1200" easeType="BackEaseOut"/>
				<Item value="255" time="2200"/>
			</AlphaAnimation>
		</Image>
		<!--3-->
		<Image w="412" h="189" x="0" y="110" src="ff.png">
			<!--位移-->
			<PositionAnimation loop="false">
				<Item x="0" y="190" time="980" easeType="BackEaseOut"/>
				<Item x="0" y="120" time="1980"/>
			</PositionAnimation>
			<!--透明度-->
			<AlphaAnimation loop="false">
				<Item value="0" time="0"/>
				<Item value="0" time="980" easeType="BackEaseOut"/>
				<Item value="255" time="1180"/>
				<Item value="255" time="1980"/>
			</AlphaAnimation>
		</Image>
		<!--2-->
		<Image w="412" h="184" x="0" y="115" src="ee.png">
			<!--位移-->
			<PositionAnimation loop="false">
				<Item x="0" y="210" time="900" easeType="BackEaseOut"/>
				<Item x="0" y="130" time="1900"/>
			</PositionAnimation>
			<!--透明度-->
			<AlphaAnimation loop="false">
				<Item value="0" time="0"/>
				<Item value="0" time="900" easeType="BackEaseOut"/>
				<Item value="255" time="1100"/>
				<Item value="255" time="1900"/>
			</AlphaAnimation>
		</Image>
		<!--风车-->
		<Image w="412" h="317" x="0" y="50" src="dd.png">
			<!--位移-->
			<PositionAnimation loop="false">
				<Item x="0" y="190" time="800" easeType="QuintEaseOut"/>
				<Item x="0" y="50" time="1800"/>
			</PositionAnimation>
			<!--透明度-->
			<AlphaAnimation loop="false">
				<Item value="0" time="0"/>
				<Item value="0" time="801" easeType="BackEaseOut"/>
				<Item value="255" time="1000"/>
				<Item value="255" time="1800"/>
			</AlphaAnimation>
		</Image>
		<Image w="412" h="88" x="0" y="165" src="cc.png">
			<!--位移-->
			<PositionAnimation loop="false">
				<Item x="0" y="255" time="700" easeType="BackEaseOut"/>
				<Item x="0" y="165" time="1700"/>
			</PositionAnimation>
			<!--透明度-->
			<AlphaAnimation loop="false">
				<Item value="0" time="0"/>
				<Item value="0" time="700" easeType="BackEaseOut"/>
				<Item value="255" time="900"/>
				<Item value="255" time="1700"/>
			</AlphaAnimation>
		</Image>
		<Image w="412" h="140" x="0" y="140" src="bb.png">
			<!--位移-->
			<PositionAnimation loop="false">
				<Item x="0" y="250" time="600" easeType="BackEaseOut"/>
				<Item x="0" y="140" time="1600"/>
			</PositionAnimation>
			<!--透明度-->
			<AlphaAnimation loop="false">
				<Item value="0" time="0"/>
				<Item value="0" time="600" easeType="BackEaseOut"/>
				<Item value="255" time="800"/>
				<Item value="255" time="1600"/>
			</AlphaAnimation>
		</Image>
		<!--1-->
		<Image w="412" h="55" x="0" y="180" src="aa.png">
			<!--位移-->
			<PositionAnimation loop="false">
				<Item x="0" y="215" time="0" easeType="CubicEaseInOut"/>
				<Item x="0" y="180" time="1000"/>
			</PositionAnimation>
		</Image>
		<Image w="412" h="412" src="bg.png" xfermode="dst_in"/>
	</Group>
	<!-- 其他 -->
	<Group y="540-1250+35-35*#YC_Ani1">
		<DateTime x="540" y="1240" align="center" alignV="center" color="#ffc855" size="110" formatExp="ifelse(#time_format,'HH:mm','h:mm')" fontFamily="mipro-heavy"/>
		<DateTime x="540" y="1320" align="center" alignV="center" color="#ffc855" size="38" format="M/dd EEEE" fontFamily="mipro-normal"/>
		<Group visibility="#battery_enable">
			<!-- 电池模组 -->
			<Var name="dcmz" expression="int((#battery_level))"/>
			<Group x="520" y="1370" visibility="!(#battery_state==1||#battery_state==3)">
				<Image src="b/0.png" visibility="le(#dcmz,10)" alignV="center" align="left"/>
				<Image src="b/1.png" visibility="gt(#dcmz,10)*le(#dcmz,25)" alignV="center" align="left"/>
				<Image src="b/2.png" visibility="gt(#dcmz,25)*le(#dcmz,50)" alignV="center" align="left"/>
				<Image src="b/3.png" visibility="gt(#dcmz,50)*le(#dcmz,75)" alignV="center" align="left"/>
				<Image src="b/4.png" visibility="gt(#dcmz,75)*le(#dcmz,100)" alignV="center" align="left"/>
			</Group>
			<Group x="520" y="1370" visibility="#battery_state==1||#battery_state==3">
				<Image src="c/0.png" visibility="le(#dcmz,10)" alignV="center" align="left"/>
				<Image src="c/1.png" visibility="gt(#dcmz,10)*le(#dcmz,25)" alignV="center" align="left"/>
				<Image src="c/2.png" visibility="gt(#dcmz,25)*le(#dcmz,50)" alignV="center" align="left"/>
				<Image src="c/3.png" visibility="gt(#dcmz,50)*le(#dcmz,75)" alignV="center" align="left"/>
				<Image src="c/4.png" visibility="gt(#dcmz,75)*le(#dcmz,100)" alignV="center" align="left"/>
			</Group>
			<Text x="510" y="1370" align="right" alignV="center" color="#ffffff" size="30" textExp="#battery_level" bold="true"/>
		</Group>
		<Array y="40*#battery_enable+1370-!#lunar_calendar_enable*80" count="4" indexName="_i" visibility="#notification_enable">
			<Image x="540+#_i*106-106/2*(4-1)" w="76" h="76" align="center" srcType="ApplicationIcon" srcExp="@noticeApp[#_i]" visibility="#preview_mode"/>
			<Image x="540+#_i*106-106/2*#noticeCount" w="76" h="76" align="center" srcType="ApplicationIcon" srcExp="@noticePkg[#_i]" visibility="#_i{=#noticeCount**!#preview_mode"/>
		</Array>
	</Group>
</Aod>