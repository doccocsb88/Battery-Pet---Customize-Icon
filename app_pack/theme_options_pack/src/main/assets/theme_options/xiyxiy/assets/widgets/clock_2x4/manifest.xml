<?xml version="1.0" encoding="utf-8"?>
<Clock frameRate="90" resDensity="480" scaleByDensity="false" screenWidth="1080" type="awesome" useVariableUpdater="Battery,DateTime.Day,DateTime.Hour,DateTime.Minute,DateTime.Second" version="2">
	<Var name="sfrn" expression="eq((#year%4),0)*ne((#year%100),0)+eq((#year%400),0)"/>
	<Var name="jths" expression="86400-#hour24*60*60-#minute*60-#second"/>
	<Var name="bzhs" expression="604800-(ifelse(eq(#day_of_week-1,0),7,#day_of_week-1)-1)*86400-#hour24*60*60-#minute*60-#second"/>
	<Var name="byhs" expression="((eq(#month,0)+eq(#month,2)+eq(#month,4)+eq(#month,6)+eq(#month,7)+eq(#month,9)+eq(#month,11))*31+eq(#month,1)*ifelse(#sfrn,29,28)+(eq(#month,3)+eq(#month,5)+eq(#month,8)+eq(#month,10))*30)*24*60*60-(#date-1)*24*60*60-#hour24*60*60-#minute*60-#second"/>
	<Var name="bygq" expression="(((eq(#month,0)+eq(#month,2)+eq(#month,4)+eq(#month,6)+eq(#month,7)+eq(#month,9)+eq(#month,11))*31+eq(#month,1)*ifelse(#sfrn,29,28)+(eq(#month,3)+eq(#month,5)+eq(#month,8)+eq(#month,10))*30)*24*60*60)"/>
	<Var name="bybfb" expression="((eq(#month,0)+eq(#month,2)+eq(#month,4)+eq(#month,6)+eq(#month,7)+eq(#month,9)+eq(#month,11))*31+eq(#month,1)*ifelse(#sfrn,29,28)+(eq(#month,3)+eq(#month,5)+eq(#month,8)+eq(#month,10))*30)-(#date-1)"/>
	<Var name="bfb" expression="100*#bybfb/(((eq(#month,0)+eq(#month,2)+eq(#month,4)+eq(#month,6)+eq(#month,7)+eq(#month,9)+eq(#month,11))*31+eq(#month,1)*ifelse(#sfrn,29,28)+(eq(#month,3)+eq(#month,5)+eq(#month,8)+eq(#month,10))*30))"/>
	<Var alias="今天剩余时间" name="remaining_time" expression="int((#remaining_hour*60*60+#remaining_minute*60+#remaining_second)/86400*100)"/>
	<Var alias="今天剩余分钟" name="remaining" expression="int(1440-(#hour24*60+#minute))"/>
	<Var alias="当前剩余小时" name="remaining_hour" expression="23-#hour24"/>
	<Var alias="当前剩余分钟" name="remaining_minute" expression="59-#minute"/>
	<Var alias="当前剩余秒" name="remaining_second" expression="60-#second"/>
	<Var alias="是否闰年变量" name="leap_year" expression="eq((#year%4),0)*ne((#year%100),0)+eq((#year%400),0)"/>
	<Var alias="今年已过去天数" name="past_days" expression="gt(#month+1,1)*31+(28+#lya)*gt(#month+1,2)+gt(#month+1,3)*31+gt(#month+1,4)*30+gt(#month+1,5)*31+gt(#month+1,6)*30+gt(#month+1,7)*31+gt(#month+1,8)*31+gt(#month+1,9)*30+gt(#month+1,10)*31+gt(#month+1,11)*30+gt(#month+1,12)*31+#date"/>
	<Var alias="今年剩余天数" name="remaining_days" expression="365+#leap_year-#past_days"/>
	<Var alias="今年剩余天数比例" name="remaining_dayss" expression="int((#past_days)/(365+#leap_year)*100)"/>
	<VariableBinders>
		<ContentProviderBinder name="WeatherProvider" uri="content://weather/actualWeatherData/1" columns="city_id,city_name,weather_type,aqilevel,description,temperature,forecast_type,tmphighs,tmplows,wind,humidity,sunrise,sunset,pressure,weathernamesfrom,forecast_type,publish_time" countName="hasweather">
			<Variable name="weather_city_id" type="string" column="city_id"/>
			<Variable name="weather_location" type="string" column="city_name"/>
			<Variable name="weather_id" type="int" column="weather_type"/>
			<Variable name="weather_temperature" type="int" column="temperature"/>
			<Variable name="weather_temperature" type="string" column="temperature"/>
			<Variable name="weather_temperature_range" type="string" column="temperature_range"/>
			<Variable name="weather_aqi" type="int" column="aqilevel"/>
			<Variable name="weather_sunrise" type="int" column="sunrise"/>
			<Variable name="weather_sunset" type="int" column="sunset"/>
			<Variable name="weather_forecast_type" type="int" column="forecast_type"/>
			<Variable name="weather_wind" type="string" column="wind"/>
			<Variable name="weather_pressure" type="int" column="pressure"/>
			<Variable name="weather_humidity" type="int" column="humidity"/>
			<Variable name="weather_type" type="string" column="weather_type"/>
			<Variable name="weather_description" type="string" column="description"/>
			<Variable name="weather_weathernamesfrom" type="string" column="weathernamesfrom"/>
			<Variable name="weather_temphigh" type="string" column="tmphighs"/>
			<Variable name="weather_templow" type="string" column="tmplows"/>
			<Variable name="weather_publish_time" type="string" column="publish_time"/>
			<Trigger>
				<!-- 天气 -->
				<VariableCommand name="weatherId" expression="ifelse(#weather_id}25||#weather_id{0,0, (#weather_id}=4**#weather_id{=6||#weather_id}=8**#weather_id{=11||#weather_id==25),4,#weather_id}=13**#weather_id{=17,13 ,#weather_id}=18**#weather_id{=21||#weather_id==23,18,#weather_id)"/>
			</Trigger>
		</ContentProviderBinder>
		<!-- 注意：不可卸载 小米健康App -->
		<ContentProviderBinder name="MiSteps" uri="content://com.mi.health.provider.main/activity/steps/brief" column="steps,goal,distance,energy,strength_duration,summary" countName="hasSteps">
			<Variable name="MiSteps_steps" type="string" column="steps"/>
			<Variable name="MiSteps_goal" type="string" column="goal"/>
			<Variable name="MiSteps_distance" type="string" column="distance"/>
			<Variable name="MiSteps_energy" type="string" column="energy"/>
			<Variable name="MiSteps_strength_duration" type="string" column="strength_duration"/>
			<Variable name="MiSteps_summary" type="string" column="summary"/>
		</ContentProviderBinder>
		<BroadcastBinder action="initialization">
			<Variable name="MiSteps_steps" type="string" extra="MiSteps_steps"/>
			<Variable name="word_3" type="string" extra="word_3"/>
		</BroadcastBinder>
	</VariableBinders>
	<ExternalCommands>
		<Trigger action="resume,pause">
			<AnimationCommand command="play" target="qq"/>
			<AnimationCommand command="play" target="qq2"/>
			<BinderCommand name="MiSteps" command="refresh"/>
		</Trigger>
		<Trigger action="resume">
			<AnimationCommand target="framerateControllerAni" command="play"/>
			<AnimationCommand target="YC_Ani1" command="play"/>
			<AnimationCommand target="YC_Ani2" command="play"/>
			<AnimationCommand target="YC_Ani3" command="play"/>
			<AnimationCommand target="YC_Ani4" command="play"/>
			<AnimationCommand target="YC_Ani5" command="play"/>
			<AnimationCommand target="YC_Ani6" command="play"/>
			<AnimationCommand target="YC_Ani7" command="play"/>
			<AnimationCommand target="YC_Ani52" command="play"/>
			<Command target="ms_Ani.animation" value="play"/>
			<Command target="mm_Ani.animation" value="play"/>
			<Command target="aphms_Ani.animation" value="play"/>
			<Command target="aphmm_Ani.animation" value="play"/>
		</Trigger>
		<Trigger action="pause">
			<AnimationCommand target="framerateControllerAni" command="play(0,0)"/>
			<AnimationCommand target="YC_Ani1" command="play(0,0)"/>
			<AnimationCommand target="YC_Ani2" command="play(0,0)"/>
			<AnimationCommand target="YC_Ani3" command="play(0,0)"/>
			<AnimationCommand target="YC_Ani4" command="play(0,0)"/>
			<AnimationCommand target="YC_Ani5" command="play(0,0)"/>
			<AnimationCommand target="YC_Ani6" command="play(0,0)"/>
			<AnimationCommand target="YC_Ani7" command="play(0,0)"/>
			<AnimationCommand target="YC_Ani52" command="play(0,0)"/>
			<VariableCommand name="sett_y" expression="970" persist="true"/>
			<VariableCommand name="sett_v" expression="0" persist="true"/>
		</Trigger>
	</ExternalCommands>
	<!-- 动画 -->
	<Var name="YC_Ani1">
		<VariableAnimation loop="false" initPause="false">
			<AniFrame value="0" time="0" easeType="CubicEaseInOut"/>
			<AniFrame value="1" time="1100"/>
		</VariableAnimation>
	</Var>
	<Var name="YC_Ani2">
		<VariableAnimation loop="false" initPause="false">
			<AniFrame value="0" time="50" easeType="CubicEaseInOut"/>
			<AniFrame value="1" time="1200"/>
		</VariableAnimation>
	</Var>
	<Var name="YC_Ani3">
		<VariableAnimation loop="false" initPause="false">
			<AniFrame value="0" time="100" easeType="CubicEaseInOut"/>
			<AniFrame value="1" time="1300"/>
		</VariableAnimation>
	</Var>
	<Var name="YC_Ani4">
		<VariableAnimation loop="false" initPause="false">
			<AniFrame value="0" time="150" easeType="CubicEaseInOut"/>
			<AniFrame value="1" time="1400"/>
		</VariableAnimation>
	</Var>
	<Var name="YC_Ani5">
		<VariableAnimation loop="false" initPause="false">
			<AniFrame value="0" time="200" easeType="CubicEaseInOut"/>
			<AniFrame value="1" time="1500"/>
		</VariableAnimation>
	</Var>
	<Var name="YC_Ani6">
		<VariableAnimation loop="false" initPause="false">
			<AniFrame value="0" time="250" easeType="CubicEaseInOut"/>
			<AniFrame value="1" time="1600"/>
		</VariableAnimation>
	</Var>
	<Var name="YC_Ani7">
		<VariableAnimation loop="false" initPause="false">
			<AniFrame value="0" time="300" easeType="CubicEaseInOut"/>
			<AniFrame value="1" time="1700"/>
		</VariableAnimation>
	</Var>
	<Var name="YC_Ani8">
		<VariableAnimation loop="false" initPause="false">
			<AniFrame value="0" time="350" easeType="CubicEaseInOut"/>
			<AniFrame value="1" time="1800"/>
		</VariableAnimation>
	</Var>
	<Var name="YC_Ani9">
		<VariableAnimation loop="false" initPause="false">
			<AniFrame value="0" time="400" easeType="CubicEaseInOut"/>
			<AniFrame value="1" time="1900"/>
		</VariableAnimation>
	</Var>
	<Var name="YC_Ani52">
		<VariableAnimation loop="false" initPause="false">
			<AniFrame value="0" time="300" easeType="CubicEaseInOut"/>
			<AniFrame value="1" time="1400"/>
			<AniFrame value="0" time="1700"/>
		</VariableAnimation>
	</Var>
	<!--    秒钟十(变量动画） -->
	<Var name="ms_Ani">
		<VariableAnimation loop="false" initPause="false" resetOnRestart="true">
			<Item value="40" time="0" easeType="BackEaseOut"/>
			<Item value="0" time="700"/>
			<Item value="0" time="9300" easeType="QuintEaseIn"/>
			<Item value="-40" time="10000"/>
		</VariableAnimation>
	</Var>
	<Var name="aphms_Ani">
		<VariableAnimation loop="false" initPause="false" resetOnRestart="true">
			<Item value="102" time="0" easeType="BackEaseOut"/>
			<Item value="255" time="700"/>
			<Item value="255" time="9300" easeType="QuintEaseIn"/>
			<Item value="102" time="10000"/>
		</VariableAnimation>
	</Var>
	<!--    秒钟个(变量动画） -->
	<Var name="mm_Ani">
		<VariableAnimation loop="false" initPause="false" resetOnRestart="true">
			<Item value="40" time="0" easeType="BackEaseOut"/>
			<Item value="0" time="500" easeType="QuintEaseIn"/>
			<Item value="-40" time="1000"/>
		</VariableAnimation>
	</Var>
	<Var name="aphmm_Ani">
		<VariableAnimation loop="false" initPause="false" resetOnRestart="true">
			<Item value="102" time="0" easeType="BackEaseOut"/>
			<Item value="255" time="500"/>
			<Item value="255" time="700" easeType="QuintEaseIn"/>
			<Item value="102" time="1000"/>
		</VariableAnimation>
	</Var>
	<!--    秒钟位移(变量动画） -->
	<VarArray type="number">
		<Vars>
			<Var name="miaog" index="#second%10"/>
		</Vars>
		<Items>
			<Item value="0"/>
			<Item value="1"/>
			<Item value="2"/>
			<Item value="3"/>
			<Item value="4"/>
			<Item value="5"/>
			<Item value="6"/>
			<Item value="7"/>
			<Item value="8"/>
			<Item value="9"/>
		</Items>
	</VarArray>
	<VarArray type="number">
		<Vars>
			<Var name="miaos" index="#second/10"/>
		</Vars>
		<Items>
			<Item value="0"/>
			<Item value="1"/>
			<Item value="2"/>
			<Item value="3"/>
			<Item value="4"/>
			<Item value="5"/>
		</Items>
	</VarArray>
	<!-- 动画触发事件 -->
	<Var name="time3" expression="#miaos" threshold="1">
		<Trigger>
			<Command target="ms_Ani.animation" value="play"/>
			<Command target="aphms_Ani.animation" value="play"/>
		</Trigger>
	</Var>
	<Var name="time4" expression="#miaog" threshold="1">
		<Trigger>
			<Command target="mm_Ani.animation" value="play"/>
			<Command target="aphmm_Ani.animation" value="play"/>
		</Trigger>
	</Var>
	<!-- 颜色 -->
	<Var name="r" values="255,0,255,255,255,19,117,73" type="number[]"/>
	<Var name="g" values="255,0,90,135,195,196,119,78" type="number[]"/>
	<Var name="b" values="255,0,88,83,0,167,254,192" type="number[]"/>
	<!-- 时钟底板 -->
	<Group y="0" x="0" visibility="1">
		<Group x="0" visibility="1">
			<!-- 日期触摸 -->
			<Button align="left" alignV="center" h="90" w="400" y="0.137*#view_height" x="45" visibility="1">
				<Triggers>
					<Trigger action="up">
						<IntentCommand action="android.intent.action.MAIN" package="com.android.calendar" class="com.android.calendar.AllInOneActivity"/>
					</Trigger>
				</Triggers>
			</Button>
			<Button align="left" alignV="center" h="60" w="100" x="70+#timea.bmp_width+#timeb.bmp_width+#timec.bmp_width+#timed.bmp_width" y="0.488*#view_height-58" visibility="1">
				<Triggers>
					<Trigger action="up">
						<IntentCommand action="android.intent.action.MAIN" package="com.android.calendar" class="com.android.calendar.AllInOneActivity"/>
					</Trigger>
				</Triggers>
			</Button>
			<Button align="left" alignV="center" h="120" w="#tdate.bmp_width" y="0.852*#view_height" x="45" visibility="1">
				<Triggers>
					<Trigger action="up">
						<IntentCommand action="android.intent.action.MAIN" package="com.android.calendar" class="com.android.calendar.AllInOneActivity"/>
					</Trigger>
				</Triggers>
			</Button>
			<Button align="left" alignV="center" h="50" w="200" y="0.852*#view_height-30" x="45+#tdate.bmp_width" visibility="1">
				<Triggers>
					<Trigger action="up">
						<IntentCommand action="android.intent.action.MAIN" package="com.android.calendar" class="com.android.calendar.AllInOneActivity"/>
					</Trigger>
				</Triggers>
			</Button>
			<!-- 天气触摸 -->
			<Button align="left" alignV="center" h="50" w="200" x="45+#tdate.bmp_width" y="0.852*#view_height+30" visibility="1">
				<Triggers>
					<Trigger action="up">
						<IntentCommand action="android.intent.action.MAIN" package="com.miui.weather2" class="com.miui.weather2.ActivityWeatherMain"/>
					</Trigger>
				</Triggers>
			</Button>
			<!-- 农历年 -->
			<Group x="250">
				<Group x="-204*#YC_Ani1" y="0.137*#view_height" visibility="eq(#clock_num,0)" alpha="255*#YC_Ani1">
					<DateTime color="#ffffff" x="0" y="0" align="left" alignV="center" format="YYA年" size="97" fontFamily="mipro-heavy" name="Datew" centerX="#Datew.text_width"/>
					<Image src="sz_0.png" visibility="1" align="center" alignV="center" x="50+#Datew.text_width" y="0"/>
				</Group>
				<Group x="-204*#YC_Ani1" y="0.137*#view_height" visibility="eq(#clock_num,1)" alpha="255*#YC_Ani1">
					<DateTime color="#000000" x="0" y="0" align="left" alignV="center" format="YYA年" size="97" fontFamily="mipro-heavy" name="Datew" centerX="#Datew.text_width"/>
					<Image src="sz_1.png" visibility="1" align="center" alignV="center" x="50+#Datew.text_width" y="0"/>
				</Group>
			</Group>
			<!-- 1 -->
			<Group x="250">
				<Group visibility="eq(#sjys_num,0)" y="0.488*#view_height" x="-204*#YC_Ani2" alpha="255*#YC_Ani2" scaleX="#timea.bmp_width/2+#timeb.bmp_width/2" scaleY="192/2" scale="1">
					<Image tint="argb(255,#r[#sz_color],#g[#sz_color],#b[#sz_color])" src="t/time.png" x="1" alignV="center" align="left" visibility="eq(#time_format,0)" centerX="#timea.bmp_width" name="timea" srcid="ifelse(eq(#hour12,0),1,#hour12/10)"/>
					<Image tint="argb(255,#r[#sz_color],#g[#sz_color],#b[#sz_color])" src="t/time.png" x="1" alignV="center" align="left" visibility="eq(#time_format,1)" centerX="#timea.bmp_width" name="timea" srcid="int(#hour24/10)"/>
					<Image tint="argb(255,#r[#sz_color],#g[#sz_color],#b[#sz_color])" src="t/time.png" x="1+#timea.bmp_width" alignV="center" align="left" visibility="eq(#time_format,0)" centerX="#timeb.bmp_width" name="timeb" srcid="ifelse(eq(#hour12,0),2,#hour12%10)"/>
					<Image tint="argb(255,#r[#sz_color],#g[#sz_color],#b[#sz_color])" src="t/time.png" x="1+#timea.bmp_width" alignV="center" align="left" visibility="eq(#time_format,1)" centerX="#timeb.bmp_width" name="timeb" srcid="#hour24%10"/>
				</Group>
				<Group visibility="eq(#sjys_num,0)" y="0.488*#view_height" x="-204*#YC_Ani3" alpha="255*#YC_Ani3" scaleX="#timec.bmp_width/2+#timed.bmp_width/2" scaleY="192/2" scale="1">
					<Image tint="argb(255,#r[#sz_color],#g[#sz_color],#b[#sz_color])" src="t/time.png" x="1+#timea.bmp_width+#timeb.bmp_width" alignV="center" align="left" centerX="#timec.bmp_width" name="timec" srcid="int(#minute/10)"/>
					<Image tint="argb(255,#r[#sz_color],#g[#sz_color],#b[#sz_color])" src="t/time.png" x="1+#timea.bmp_width+#timeb.bmp_width+#timec.bmp_width" alignV="center" align="left" centerX="#timed.bmp_width" name="timed" srcid="#minute%10"/>
				</Group>
				<!-- 2 -->
				<Group visibility="eq(#sjys_num,1)" y="0.488*#view_height" x="-204*#YC_Ani2" alpha="255*#YC_Ani2" scaleX="#timea.bmp_width/2+#timeb.bmp_width/2" scaleY="192/2" scale="1">
					<Image tint="argb(255,#r[#sz_color],#g[#sz_color],#b[#sz_color])" src="t/time1.png" x="1" alignV="center" align="left" visibility="eq(#time_format,0)" centerX="#timea.bmp_width" name="timea" srcid="ifelse(eq(#hour12,0),1,#hour12/10)"/>
					<Image tint="argb(255,#r[#sz_color],#g[#sz_color],#b[#sz_color])" src="t/time1.png" x="1" alignV="center" align="left" visibility="eq(#time_format,1)" centerX="#timea.bmp_width" name="timea" srcid="int(#hour24/10)"/>
					<Image tint="argb(255,#r[#sz_color],#g[#sz_color],#b[#sz_color])" src="t/time1.png" x="1+#timea.bmp_width" alignV="center" align="left" visibility="eq(#time_format,0)" centerX="#timeb.bmp_width" name="timeb" srcid="ifelse(eq(#hour12,0),2,#hour12%10)"/>
					<Image tint="argb(255,#r[#sz_color],#g[#sz_color],#b[#sz_color])" src="t/time1.png" x="1+#timea.bmp_width" alignV="center" align="left" visibility="eq(#time_format,1)" centerX="#timeb.bmp_width" name="timeb" srcid="#hour24%10"/>
				</Group>
				<Group visibility="eq(#sjys_num,1)" y="0.488*#view_height" x="-204*#YC_Ani3" alpha="255*#YC_Ani3" scaleX="#timec.bmp_width/2+#timed.bmp_width/2" scaleY="192/2" scale="1">
					<Image tint="argb(255,#r[#sz_color],#g[#sz_color],#b[#sz_color])" src="t/time1.png" x="1+#timea.bmp_width+#timeb.bmp_width" alignV="center" align="left" centerX="#timec.bmp_width" name="timec" srcid="int(#minute/10)"/>
					<Image tint="argb(255,#r[#sz_color],#g[#sz_color],#b[#sz_color])" src="t/time1.png" x="1+#timea.bmp_width+#timeb.bmp_width+#timec.bmp_width" alignV="center" align="left" centerX="#timed.bmp_width" name="timed" srcid="#minute%10"/>
				</Group>
				<!-- 3 -->
				<Group visibility="eq(#sjys_num,2)" y="0.488*#view_height" x="-204*#YC_Ani2" alpha="255*#YC_Ani2" scaleX="#timea.bmp_width/2+#timeb.bmp_width/2" scaleY="192/2" scale="1">
					<Image tint="argb(255,#r[#sz_color],#g[#sz_color],#b[#sz_color])" src="t/time2.png" x="1" alignV="center" align="left" visibility="eq(#time_format,0)" centerX="#timea.bmp_width" name="timea" srcid="ifelse(eq(#hour12,0),1,#hour12/10)"/>
					<Image tint="argb(255,#r[#sz_color],#g[#sz_color],#b[#sz_color])" src="t/time2.png" x="1" alignV="center" align="left" visibility="eq(#time_format,1)" centerX="#timea.bmp_width" name="timea" srcid="int(#hour24/10)"/>
					<Image tint="argb(255,#r[#sz_color],#g[#sz_color],#b[#sz_color])" src="t/time2.png" x="1+#timea.bmp_width" alignV="center" align="left" visibility="eq(#time_format,0)" centerX="#timeb.bmp_width" name="timeb" srcid="ifelse(eq(#hour12,0),2,#hour12%10)"/>
					<Image tint="argb(255,#r[#sz_color],#g[#sz_color],#b[#sz_color])" src="t/time2.png" x="1+#timea.bmp_width" alignV="center" align="left" visibility="eq(#time_format,1)" centerX="#timeb.bmp_width" name="timeb" srcid="#hour24%10"/>
				</Group>
				<Group visibility="eq(#sjys_num,2)" y="0.488*#view_height" x="-204*#YC_Ani3" alpha="255*#YC_Ani3" scaleX="#timec.bmp_width/2+#timed.bmp_width/2" scaleY="192/2" scale="1">
